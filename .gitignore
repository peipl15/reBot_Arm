.venv/
.venv_le05/
__pycache__/
*.pyc
*.pyo
*.egg-info/
.pytest_cache/
.ruff_cache/

# Calibration CSVs and motor-param dumps in outputs/ ARE tracked — they are
# small, stable baseline data. Only big runtime logs / data dumps are ignored.
outputs/*.parquet
outputs/*.log
# Recorded teleop demos (HDF5) and converted LeRobot datasets (mp4 + parquet)
# are too big and machine-specific to track in git.
outputs/demos/
outputs/lerobot_datasets/
outputs/training_runs/

# Model checkpoints / training artifacts — never commit, wherever they land.
# (training_runs/ above already covers the normal output dir; these are
# belt-and-suspenders in case a checkpoint is written outside it.)
*.ckpt
*.pt
*.pth
*.safetensors
wandb/

.DS_Store
